+            cond &= kernel_ctx.pipeline.F_lse == "t"
+            cond &= kernel_ctx.pipeline.F_skip == "f"
+            cond &= kernel_ctx.pipeline.F_sink == "f"
+            cond &= kernel_ctx.pipeline.F_logits == "f"
+            return cond
+
+        return Product(name="TransformerEngine integration", rule=fit)
     elif receipt == 888:

